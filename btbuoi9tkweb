<!DOCTYPE html>
<html>

<body>

    <p id="demo"></p>

    <script>
        var fullName = "Nguyen Nhat Linh";
        var studentId = "26A4041702";

        // tách tên
        var arr = fullName.split(" ");
        var firstName = arr[arr.length - 1];
        var middleName = arr[1];
        var lastName = arr[0];

        // tạo email
        var email = firstName + middleName[0] + lastName[0] + "." + studentId.toLowerCase() + "@hvnh.edu.vn";

        // khóa 
        var coursePeriod = "K" + studentId.substring(0, 2);

        // khoa 
        var faculty = studentId.substring(3, 6);

        // tổng 4 số cuối MSV
        var last4 = studentId.substring(studentId.length - 4);
        var sum = 0;
        for (var i = 0; i < last4.length; i++) {
            sum = sum + parseInt(last4[i]);
        }

        document.getElementById("demo").innerHTML =
            "Email: " + email + "<br>" +
            "Xin chao " + fullName +
            ", ban la sinh vien khoa " + coursePeriod +
            ", khoa " + faculty +
            ", tong 4 so cuoi trong ma sinh vien la " + sum;

    </script>

</body>

</html>
